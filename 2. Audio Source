mkdir -p ~/.config/pulse

echo '.include /etc/pulse/default.pa
set-default-sink alsa_output.pci-0000_00_1b.0.analog-stereo
set-source-port alsa_input.pci-0000_00_1b.0.analog-stereo analog-input-linein' > ~/.config/pulse/default.pa

$ alsamixer
set autio MM to 0
UNmute!

sudo alsactl store
sudo systemctl enable alsa-restore
sudo systemctl enable alsa-state
sudo systemctl start alsa-state
